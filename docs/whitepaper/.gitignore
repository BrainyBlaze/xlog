# LaTeX build artifacts
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.run.xml
*.synctex.gz
*.toc
*.lof
*.lot
*.nav
*.snm
*.vrb

# Keep figure PDFs committed, ignore any build temp
figures/*.tmp

# Build output — main.pdf is rebuilt locally via `latexmk -pdf main.tex`
# and is not committed (would create large binary diffs on every source change).
# Figure PDFs under figures/ remain tracked so the whitepaper builds without mmdc.
main.pdf
