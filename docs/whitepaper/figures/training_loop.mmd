flowchart TB
  classDef cpu fill:#fff3e6,stroke:#cc7a00,stroke-width:1px,color:#663
  classDef gpu fill:#eef5ff,stroke:#3366aa,stroke-width:1px,color:#113
  classDef loss fill:#ffecec,stroke:#cc3333,stroke-width:1px,color:#522

  images["Digit images"]:::cpu
  cnn["PyTorch forward<br/>(CNN)"]:::gpu
  softmax["Softmax outputs<br/>= leaf weights"]:::gpu

  subgraph CIRC["XGCF circuit (cached on GPU)"]
    fwd["Forward pass<br/>level-parallel kernels<br/>→ log P(query)"]:::gpu
    bwd["Backward pass<br/>level-parallel kernels<br/>→ ∂loss / ∂leaf_weight"]:::gpu
  end

  nll["NLL loss<br/>= −log P(addition(i,j,s))"]:::loss
  dlpack["Gradients via DLPack<br/>(zero-copy)"]:::gpu
  opt["PyTorch backward<br/>+ Adam step"]:::gpu
  next["Next iteration<br/>(new weights,<br/>same circuit)"]:::cpu

  images --> cnn --> softmax --> fwd --> nll --> bwd --> dlpack --> opt --> next
  next -.-> cnn
