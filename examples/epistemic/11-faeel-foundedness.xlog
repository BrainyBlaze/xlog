// FAEEL accepts self-supporting modal rules only when an
// independent founded support exists. founded() is supported both by base() and
// by `possible founded()`; the independent base() foundation makes the
// self-support founded, so FAEEL accepts it. Expect: founded with rows: 1.

#pragma epistemic_mode = faeel

pred base().
pred founded().

base().

founded() :- base().
founded() :- possible founded().

?- founded().
