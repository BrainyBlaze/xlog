// Count aggregate lifting over a small finite uncertain domain.

0.5::edge(1, 1).
0.5::edge(1, 2).
0.5::edge(1, 3).
0.5::edge(1, 4).
0.5::edge(1, 5).
0.5::edge(1, 6).
0.5::edge(1, 7).
0.5::edge(1, 8).
0.5::edge(1, 9).
0.5::edge(1, 10).
0.5::edge(1, 11).
0.5::edge(1, 12).
0.5::edge(1, 13).
0.5::edge(1, 14).
0.5::edge(1, 15).
0.5::edge(1, 16).
0.5::edge(1, 17).

out_degree(X, count(Y)) :- edge(X, Y).

query(out_degree(1, 8)).

