// Triangle detection in a directed graph.

pred edge(u32, u32).
pred triangle(u32, u32, u32).

edge(1, 2).
edge(2, 3).
edge(3, 1).

edge(1, 3).
edge(3, 4).
edge(4, 1).

// A canonical triangle representation to avoid duplicates.
triangle(A, B, C) :- edge(A, B), edge(B, C), edge(C, A), A < B, B < C.

?- triangle(A, B, C).

