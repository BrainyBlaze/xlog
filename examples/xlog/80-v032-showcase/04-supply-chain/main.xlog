// =============================================================================
// Supply Chain Analytics - Complete Self-Contained Example
// =============================================================================
// Demonstrates working features:
//   - symbol type for product/supplier identifiers
//   - Recursive rules for Bill of Materials (BOM) explosion
//   - Aggregations for inventory and cost analysis
//   - Arithmetic expressions for pricing calculations
//   - Complex join patterns for supply chain optimization
//
// Domain: Manufacturing supply chain with products, suppliers, orders, warehouses
// =============================================================================

// --- Core Entity Predicates ---
pred product(symbol, symbol, symbol).        // product_id, name, category
pred supplier(symbol, symbol, symbol).       // supplier_id, name, country
pred warehouse(symbol, symbol, symbol).      // warehouse_id, name, region
pred customer(symbol, symbol, symbol).       // customer_id, name, segment

// --- Product Structure ---
pred bom(symbol, symbol, u32).               // parent_product, component, quantity
pred unit_cost(symbol, u32).                 // product_id, cost_cents
pred lead_time_days(symbol, u32).            // product_id, days

// --- Supplier Relations ---
pred supplies(symbol, symbol, u32).          // supplier_id, product_id, price_cents
pred supplier_rating(symbol, u32).           // supplier_id, rating (1-100)
pred preferred_supplier(symbol, symbol).     // product_id, supplier_id

// --- Inventory ---
pred inventory(symbol, symbol, u32).         // warehouse_id, product_id, quantity
pred reorder_point(symbol, u32).             // product_id, min_quantity
pred safety_stock(symbol, u32).              // product_id, buffer_quantity

// --- Orders and Shipping ---
pred order(symbol, symbol, symbol, u32).     // order_id, customer_id, status, timestamp
pred order_line(symbol, symbol, u32, u32).   // order_id, product_id, quantity, unit_price
pred shipment(symbol, symbol, symbol, u32).  // shipment_id, order_id, warehouse_id, ship_date

// --- Transportation ---
pred route(symbol, symbol, u32, u32).        // from_warehouse, to_warehouse, distance_km, cost_cents
pred transit_time(symbol, symbol, u32).      // from_warehouse, to_warehouse, days

// =============================================================================
// PRODUCT CATALOG
// =============================================================================

product(p001, "Laptop X1", electronics).
product(p002, "Display Panel 15in", components).
product(p003, "CPU Chip A9", components).
product(p004, "RAM Module 16GB", components).
product(p005, "SSD Drive 512GB", components).
product(p006, "Battery Pack", components).
product(p007, "Keyboard Assembly", components).
product(p008, "Motherboard", components).
product(p009, "Smartphone S5", electronics).
product(p010, "OLED Screen 6in", components).
product(p011, "Camera Module", components).
product(p012, "Power Adapter", accessories).
product(p013, "USB Cable", accessories).
product(p014, "Carrying Case", accessories).
product(p015, "Wireless Mouse", accessories).

unit_cost(p001, 80000).    // $800
unit_cost(p002, 15000).    // $150
unit_cost(p003, 25000).    // $250
unit_cost(p004, 8000).     // $80
unit_cost(p005, 12000).    // $120
unit_cost(p006, 5000).     // $50
unit_cost(p007, 3000).     // $30
unit_cost(p008, 20000).    // $200
unit_cost(p009, 60000).    // $600
unit_cost(p010, 10000).    // $100
unit_cost(p011, 4000).     // $40
unit_cost(p012, 2500).     // $25
unit_cost(p013, 500).      // $5
unit_cost(p014, 4000).     // $40
unit_cost(p015, 3500).     // $35

lead_time_days(p001, 14).
lead_time_days(p002, 7).
lead_time_days(p003, 10).
lead_time_days(p004, 5).
lead_time_days(p005, 5).
lead_time_days(p006, 7).
lead_time_days(p007, 5).
lead_time_days(p008, 10).
lead_time_days(p009, 12).
lead_time_days(p010, 8).
lead_time_days(p011, 6).
lead_time_days(p012, 3).
lead_time_days(p013, 2).
lead_time_days(p014, 4).
lead_time_days(p015, 3).

// =============================================================================
// BILL OF MATERIALS (Hierarchical Structure)
// =============================================================================

// Laptop X1 components
bom(p001, p002, 1).  // 1 Display Panel
bom(p001, p003, 1).  // 1 CPU Chip
bom(p001, p004, 2).  // 2 RAM Modules
bom(p001, p005, 1).  // 1 SSD Drive
bom(p001, p006, 1).  // 1 Battery Pack
bom(p001, p007, 1).  // 1 Keyboard
bom(p001, p008, 1).  // 1 Motherboard

// Smartphone S5 components
bom(p009, p010, 1).  // 1 OLED Screen
bom(p009, p011, 2).  // 2 Camera Modules
bom(p009, p003, 1).  // 1 CPU Chip (shared)
bom(p009, p004, 1).  // 1 RAM Module
bom(p009, p006, 1).  // 1 Battery Pack (shared)

// Motherboard sub-components (nested BOM)
bom(p008, p003, 1).  // CPU socket
bom(p008, p004, 4).  // 4 RAM slots

// =============================================================================
// SUPPLIERS
// =============================================================================

supplier(s001, "TechParts Inc", usa).
