// =============================================================================
// CUSTOMERS
// =============================================================================

customer(c001, "TechRetail Corp", enterprise).
customer(c002, "SmartBuy Inc", enterprise).
customer(c003, "Consumer Direct", retail).
customer(c004, "Government Services", government).
customer(c005, "Education Systems", education).

// =============================================================================
// ORDERS
// =============================================================================

// Status: pending=1, processing=2, shipped=3, delivered=4
order(o001, c001, pending, 20240115).
order(o002, c002, processing, 20240114).
order(o003, c003, shipped, 20240112).
order(o004, c004, delivered, 20240110).
order(o005, c001, processing, 20240116).
order(o006, c005, pending, 20240117).

order_line(o001, p001, 20, 95000).   // 20 Laptops @ $950 each
order_line(o001, p012, 20, 3000).    // 20 Power Adapters @ $30
order_line(o002, p009, 50, 70000).   // 50 Smartphones @ $700
order_line(o002, p013, 50, 600).     // 50 USB Cables @ $6
order_line(o003, p001, 10, 95000).   // 10 Laptops
order_line(o003, p015, 10, 4000).    // 10 Wireless Mice
order_line(o004, p001, 100, 85000).  // 100 Laptops @ $850 (bulk discount)
order_line(o004, p014, 100, 3500).   // 100 Cases
order_line(o005, p009, 30, 72000).   // 30 Smartphones
order_line(o006, p001, 25, 90000).   // 25 Laptops

// =============================================================================
// SHIPMENTS
// =============================================================================

shipment(sh001, o003, w001, 20240113).
shipment(sh002, o004, w002, 20240111).
shipment(sh003, o002, w003, 20240115).

// =============================================================================
// BOM EXPLOSION (Recursive)
// =============================================================================

// Full BOM explosion - all components needed to build a product
pred bom_exploded(symbol, symbol, u32).

// Base case: direct components
bom_exploded(Product, Component, Qty) :- bom(Product, Component, Qty).

// Recursive case: sub-components of components
pred bom_explosion_recursive(symbol, symbol, u32).
bom_explosion_recursive(Product, SubComponent, TotalQty) :-
    bom(Product, Component, ParentQty),
    bom_exploded(Component, SubComponent, ChildQty),
    TotalQty is ParentQty * ChildQty.

// Combine direct and recursive BOMs
pred full_bom(symbol, symbol, u32).
full_bom(Product, Component, Qty) :- bom_exploded(Product, Component, Qty).
full_bom(Product, Component, Qty) :- bom_explosion_recursive(Product, Component, Qty).

// Total component demand for a product
pred component_total(symbol, symbol, u64).
component_total(Product, Component, sum(Qty)) :- full_bom(Product, Component, Qty).

// =============================================================================
// INVENTORY ANALYTICS
// =============================================================================

// Total inventory per product across warehouses
pred total_inventory(symbol, u64).
total_inventory(ProductId, sum(Qty)) :- inventory(_, ProductId, Qty).

// Inventory value per warehouse
pred warehouse_inventory_value(symbol, u64).
warehouse_inventory_value(WarehouseId, sum(Value)) :-
    inventory(WarehouseId, ProductId, Qty),
    unit_cost(ProductId, Cost),
    Value is Qty * Cost.

// Low stock alerts (below reorder point)
pred low_stock_alert(symbol, symbol, symbol, u32, u32).
low_stock_alert(WarehouseName, ProductName, Category, CurrentQty, ReorderPt) :-
    warehouse(WarehouseId, WarehouseName, _),
    inventory(WarehouseId, ProductId, CurrentQty),
    product(ProductId, ProductName, Category),
    reorder_point(ProductId, ReorderPt),
    CurrentQty < ReorderPt.

// =============================================================================
// SUPPLIER ANALYTICS
// =============================================================================

// Products per supplier
pred supplier_product_count(symbol, u64).
supplier_product_count(SupplierId, count(ProductId)) :- supplies(SupplierId, ProductId, _).

// Best price for each product
pred min_supplier_price(symbol, u64).
min_supplier_price(ProductId, sum(Price)) :- supplies(_, ProductId, Price).

// High-rated suppliers (rating >= 85)
pred premium_supplier(symbol, symbol, symbol, u32).
premium_supplier(SupplierName, Country, SupplierId, Rating) :-
    supplier(SupplierId, SupplierName, Country),
    supplier_rating(SupplierId, Rating),
    Rating >= 85.

// Supplier diversity per product
pred product_supplier_count(symbol, u64).
product_supplier_count(ProductId, count(SupplierId)) :- supplies(SupplierId, ProductId, _).

// Single-source products (only 1 supplier - supply chain risk)
pred single_source_product(symbol, symbol, u64).
single_source_product(ProductName, Category, SupplierCount) :-
    product(ProductId, ProductName, Category),
    product_supplier_count(ProductId, SupplierCount),
    SupplierCount < 2.

// =============================================================================
// ORDER ANALYTICS
// =============================================================================

// Order line value
pred order_line_value(symbol, u32).
order_line_value(OrderId, LineValue) :-
    order_line(OrderId, _, Qty, Price),
    LineValue is Qty * Price.

// Total order value
pred order_total(symbol, u64).
order_total(OrderId, sum(LineValue)) :- order_line_value(OrderId, LineValue).

// Orders by customer
pred customer_order_count(symbol, u64).
customer_order_count(CustomerId, count(OrderId)) :- order(OrderId, CustomerId, _, _).

// Top customers (2+ orders)
pred top_customer(symbol, symbol, symbol, u64).
top_customer(CustomerName, Segment, CustomerId, OrderCount) :-
    customer(CustomerId, CustomerName, Segment),
    customer_order_count(CustomerId, OrderCount),
    OrderCount >= 2.

// Large orders (value > $5000)
pred large_order(symbol, symbol, u64).
large_order(OrderId, CustomerName, TotalValue) :-
    order(OrderId, CustomerId, _, _),
    customer(CustomerId, CustomerName, _),
    order_total(OrderId, TotalValue),
    TotalValue > 500000.

// =============================================================================
// REGIONAL ANALYTICS
// =============================================================================

// Warehouse product count
pred warehouse_product_count(symbol, u64).
warehouse_product_count(WarehouseId, count(ProductId)) :- inventory(WarehouseId, ProductId, _).

// Well-stocked warehouses (5+ products)
pred major_warehouse(symbol, symbol, symbol, u64, u64).
major_warehouse(WarehouseName, Region, WarehouseId, ProductCount, InventoryValue) :-
    warehouse(WarehouseId, WarehouseName, Region),
    warehouse_product_count(WarehouseId, ProductCount),
    warehouse_inventory_value(WarehouseId, InventoryValue),
    ProductCount >= 5.

// =============================================================================
// QUERIES
// =============================================================================

// Q1: Full BOM explosion for Laptop X1
?- full_bom(p001, Component, Quantity).

// Q2: Low stock alerts
?- low_stock_alert(Warehouse, Product, Category, CurrentQty, ReorderPoint).

// Q3: Premium suppliers
?- premium_supplier(SupplierName, Country, SupplierId, Rating).

// Q4: Single-source products (supply chain risk)
?- single_source_product(ProductName, Category, SupplierCount).

// Q5: Large orders
?- large_order(OrderId, CustomerName, TotalValue).

// Q6: Major warehouses with inventory value
?- major_warehouse(WarehouseName, Region, WarehouseId, ProductCount, InventoryValue).

// Q7: Top customers
?- top_customer(CustomerName, Segment, CustomerId, OrderCount).
