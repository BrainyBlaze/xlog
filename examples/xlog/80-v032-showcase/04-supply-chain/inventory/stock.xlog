// =============================================================================
// Inventory & Stock Management Module
// =============================================================================
// Supply chain inventory data: products, warehouses, stock levels, reorder points
//
// Features:
//   - 50+ products across multiple categories
//   - Multi-warehouse inventory tracking
//   - Daily demand and reorder point management
//   - Bill of materials for manufactured products
// =============================================================================

// --- Core Predicates ---
pred product(symbol, symbol, symbol).        // product_id, name, category
pred warehouse(symbol, symbol, symbol).      // warehouse_id, name, region
pred stock(symbol, symbol, u32).             // warehouse_id, product_id, quantity
pred unit_cost(symbol, u32).                 // product_id, cost_cents
pred reorder_point(symbol, u32).             // product_id, min_quantity
pred daily_demand(symbol, u32).              // product_id, avg_daily_units
pred lead_time_days(symbol, u32).            // product_id, supplier_lead_days

// Bill of Materials: parent_product, component_product, quantity_needed
pred bom(symbol, symbol, u32).

// =============================================================================
// WAREHOUSES (8 locations)
// =============================================================================

warehouse(wh_seattle, "Seattle Distribution Center", northwest).
warehouse(wh_portland, "Portland Fulfillment Hub", northwest).
warehouse(wh_la, "Los Angeles Mega Center", southwest).
warehouse(wh_phoenix, "Phoenix Regional Hub", southwest).
warehouse(wh_chicago, "Chicago Central Warehouse", midwest).
warehouse(wh_dallas, "Dallas Distribution Point", south).
warehouse(wh_atlanta, "Atlanta Logistics Center", southeast).
warehouse(wh_newark, "Newark East Coast Hub", northeast).

