// =============================================================================
// Shipping & Routes Module
// =============================================================================
// Logistics data: carriers, shipping routes, lanes, and transit information
//
// Features:
//   - Multiple carriers with different service levels
//   - Shipping lanes between warehouses and regions
//   - Recursive can_ship reachability for multi-hop routes
//   - Zone-based surcharges and fuel rates
// =============================================================================

// --- Core Predicates ---
pred carrier(symbol, symbol, symbol).         // carrier_id, name, service_level
pred shipping_lane(symbol, symbol, symbol).   // lane_id, origin_region, dest_region
pred carrier_rate(symbol, u32, u32).          // carrier_id, rate_per_kg_cents, fuel_surcharge_pct
pred carrier_zone(symbol, symbol).            // carrier_id, zone_id
pred zone_surcharge(symbol, u32).             // zone_id, surcharge_pct

// Direct routes between locations
pred direct_route(symbol, symbol, symbol, u32, u32). // origin, destination, carrier_id, distance_km, base_cost_cents

// Transit times
pred transit_time(symbol, symbol, symbol, u32). // origin, destination, carrier_id, days

// Delivery zones
pred delivery_zone(symbol, symbol).           // location_id, zone_id

// Carrier service areas
pred carrier_serves(symbol, symbol).          // carrier_id, region

// =============================================================================
// CARRIERS (12 carriers)
// =============================================================================

// National carriers - full coverage
carrier(carrier_fedex, "FedEx Express", express).
carrier(carrier_ups, "UPS Ground", standard).
carrier(carrier_usps, "USPS Priority", economy).
carrier(carrier_dhl, "DHL International", express).

// Regional carriers
carrier(carrier_ontrac, "OnTrac", regional).
carrier(carrier_lasership, "LaserShip", regional).
carrier(carrier_speedee, "Spee-Dee Delivery", regional).
carrier(carrier_lso, "Lone Star Overnight", regional).

// Freight carriers
carrier(carrier_xpo, "XPO Logistics", freight).
carrier(carrier_odfl, "Old Dominion", freight).
carrier(carrier_saia, "SAIA LTL Freight", freight).
carrier(carrier_estes, "Estes Express", freight).

// =============================================================================
// CARRIER RATES (rate_per_kg, fuel_surcharge_pct)
// =============================================================================

carrier_rate(carrier_fedex, 450, 18).     // $4.50/kg, 18% fuel
carrier_rate(carrier_ups, 380, 15).       // $3.80/kg, 15% fuel
carrier_rate(carrier_usps, 290, 8).       // $2.90/kg, 8% fuel
carrier_rate(carrier_dhl, 520, 22).       // $5.20/kg, 22% fuel
carrier_rate(carrier_ontrac, 320, 12).    // $3.20/kg, 12% fuel
carrier_rate(carrier_lasership, 310, 10). // $3.10/kg, 10% fuel
carrier_rate(carrier_speedee, 280, 9).    // $2.80/kg, 9% fuel
carrier_rate(carrier_lso, 340, 14).       // $3.40/kg, 14% fuel
carrier_rate(carrier_xpo, 180, 20).       // $1.80/kg, 20% fuel (freight)
carrier_rate(carrier_odfl, 165, 18).      // $1.65/kg, 18% fuel (freight)
carrier_rate(carrier_saia, 175, 19).      // $1.75/kg, 19% fuel (freight)
carrier_rate(carrier_estes, 170, 17).     // $1.70/kg, 17% fuel (freight)

// =============================================================================
// DELIVERY ZONES
// =============================================================================

// Zone definitions (proximity-based pricing)
zone_surcharge(zone_local, 0).        // Local - no surcharge
zone_surcharge(zone_metro, 5).        // Metro area - 5%
zone_surcharge(zone_regional, 10).    // Regional - 10%
zone_surcharge(zone_national, 15).    // National - 15%
zone_surcharge(zone_extended, 25).    // Extended/rural - 25%
zone_surcharge(zone_remote, 35).      // Remote areas - 35%

// Warehouse delivery zones
