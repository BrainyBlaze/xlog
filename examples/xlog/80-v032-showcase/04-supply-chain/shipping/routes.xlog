// =============================================================================
// RECURSIVE SHIPPING REACHABILITY
// =============================================================================

// Can ship directly between two locations
pred can_ship(symbol, symbol).

// Base case: direct route exists
can_ship(Origin, Destination) :- direct_route(Origin, Destination, _, _, _).

// Recursive case: can reach via intermediate hub
can_ship(Origin, Destination) :-
    direct_route(Origin, Intermediate, _, _, _),
    can_ship(Intermediate, Destination),
    Origin != Destination,
    Intermediate != Origin,
    Intermediate != Destination.

// =============================================================================
// ROUTE ANALYTICS
// =============================================================================

// Count routes per carrier
pred routes_per_carrier(symbol, u64).
routes_per_carrier(Carrier, count(Origin)) :-
    direct_route(Origin, _, Carrier, _, _).

// Cheapest route between locations
pred cheapest_route(symbol, symbol, symbol, u32).
cheapest_route(Origin, Destination, Carrier, Cost) :-
    direct_route(Origin, Destination, Carrier, _, Cost).

// Fastest route between locations
pred fastest_route(symbol, symbol, symbol, u32).
fastest_route(Origin, Destination, Carrier, Days) :-
    transit_time(Origin, Destination, Carrier, Days).

// =============================================================================
// PRIVATE PREDICATES FOR CARRIER SELECTION
// =============================================================================

// Private helper: identify if another carrier offers a cheaper option
pred cheaper_option(symbol, symbol, symbol, symbol).
cheaper_option(Origin, Destination, Carrier, CheaperCarrier) :-
    direct_route(Origin, Destination, Carrier, _, Cost1),
    direct_route(Origin, Destination, CheaperCarrier, _, Cost2),
    Carrier != CheaperCarrier,
    Cost2 < Cost1.

// Best carrier for a route: no cheaper alternative exists
pred best_carrier_for_route(symbol, symbol, symbol, u32).
best_carrier_for_route(Origin, Destination, Carrier, Cost) :-
    direct_route(Origin, Destination, Carrier, _, Cost),
    not cheaper_option(Origin, Destination, Carrier, _).

// Private helper: identify if another carrier offers a faster option
pred faster_option(symbol, symbol, symbol, symbol).
faster_option(Origin, Destination, Carrier, FasterCarrier) :-
    transit_time(Origin, Destination, Carrier, Days1),
    transit_time(Origin, Destination, FasterCarrier, Days2),
    Carrier != FasterCarrier,
    Days2 < Days1.

// Fastest carrier for a route: no faster alternative exists
pred fastest_carrier_for_route(symbol, symbol, symbol, u32).
fastest_carrier_for_route(Origin, Destination, Carrier, Days) :-
    transit_time(Origin, Destination, Carrier, Days),
    not faster_option(Origin, Destination, Carrier, _).

// Multi-carrier routes available
pred multi_carrier_route(symbol, symbol, u64).
multi_carrier_route(Origin, Destination, count(Carrier)) :-
    direct_route(Origin, Destination, Carrier, _, _).
