// =============================================================================
// DERIVED PREDICATES
// =============================================================================

// Assign tier based on Elo rating
pred player_calculated_tier(symbol, u32).
player_calculated_tier(PlayerId, Tier) :-
    player_elo(PlayerId, Rating),
    Tier is tier_from_elo(Rating).

// Helper: compute total games for win rate calculation
pred player_total_games(symbol, u32, u32, u32).
player_total_games(PlayerId, Wins, Losses, Total) :-
    season_record(PlayerId, Wins, Losses),
    Total is Wins + Losses.

// Calculate win rate for players
pred player_win_rate(symbol, u32).
player_win_rate(PlayerId, Rate) :-
    player_total_games(PlayerId, Wins, _, Total),
    Total > 0,
    Rate is win_rate(Wins, Total).

// Calculate K-factor for each player based on games played
pred player_k_factor(symbol, u32).
player_k_factor(PlayerId, K) :-
    season_record(PlayerId, Wins, Losses),
    Games is Wins + Losses,
    K is elo_k_factor(Games).

// Top ranked players (2400+ Elo rating)
pred grandmaster_player(symbol, u32).
grandmaster_player(PlayerId, Rating) :-
    player_elo(PlayerId, Rating),
    Rating >= 2400.

// Master players (2000-2399 Elo rating)
pred master_player(symbol, u32).
master_player(PlayerId, Rating) :-
    player_elo(PlayerId, Rating),
    Rating >= 2000,
    Rating < 2400.

// Players with high win rate (60%+)
pred high_win_rate_player(symbol, u32, u32).
high_win_rate_player(PlayerId, Rate, Elo) :-
    player_win_rate(PlayerId, Rate),
    Rate >= 60,
    player_elo(PlayerId, Elo).

// Elo rating gain in history (positive change)
pred elo_gain(symbol, symbol, u32).
elo_gain(PlayerId, MatchId, Gain) :-
    elo_history(PlayerId, MatchId, Before, After),
    After > Before,
    Gain is After - Before.

// Players by tier distribution
pred tier_distribution(u32, u64).
tier_distribution(Tier, count(PlayerId)) :- player_calculated_tier(PlayerId, Tier).
