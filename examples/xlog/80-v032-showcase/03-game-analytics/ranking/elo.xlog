// =============================================================================
// Elo Ranking System Module
// =============================================================================
// Demonstrates: Multiple user-defined functions with arithmetic and conditionals for rating calculations
// Contains: Elo ratings, tier system, and win rate calculations
// =============================================================================

// --- Predicate Declarations ---
pred player_elo(symbol, u32).                  // player_id, elo_rating
pred elo_history(symbol, symbol, u32, u32).    // player_id, match_id, elo_before, elo_after
pred player_tier(symbol, symbol).              // player_id, tier_name
pred season_record(symbol, u32, u32).          // player_id, wins, losses

// --- Private Helpers ---
pred base_elo(u32).
pred tier_name(u32, symbol).

base_elo(1200).  // Starting Elo rating for new players

tier_name(1, grandmaster).
tier_name(2, master).
tier_name(3, diamond).
tier_name(4, platinum).
tier_name(5, gold).
tier_name(6, silver).

// =============================================================================
// USER-DEFINED FUNCTIONS
// =============================================================================

// K-factor for Elo rating calculation based on games played
// New players (< 30 games) get K=40, intermediate K=20, veterans K=10
func elo_k_factor(GamesPlayed) = if GamesPlayed < cast(30, u32) then cast(40, u32) else if GamesPlayed < cast(100, u32) then cast(20, u32) else cast(10, u32).

// Expected score calculation (simplified integer version)
// Returns percentage * 100 (so 75 = 75% expected win rate)
func elo_expected(PlayerRating, OpponentRating) =
    if PlayerRating > OpponentRating + cast(400, u32) then cast(95, u32)
    else if PlayerRating > OpponentRating + cast(200, u32) then cast(85, u32)
    else if PlayerRating > OpponentRating + cast(100, u32) then cast(70, u32)
    else if PlayerRating > OpponentRating then cast(55, u32)
    else if PlayerRating = OpponentRating then cast(50, u32)
    else if PlayerRating > OpponentRating - cast(100, u32) then cast(45, u32)
    else if PlayerRating > OpponentRating - cast(200, u32) then cast(30, u32)
    else if PlayerRating > OpponentRating - cast(400, u32) then cast(15, u32)
    else cast(5, u32).

// Elo rating change calculation (simplified)
// Result: 100 = win, 50 = draw, 0 = loss
func elo_change(K, Expected, Result) = (K * (Result - Expected)) / cast(100, u32).

// Tier determination from Elo rating
// 2400+ = Grandmaster, 2000+ = Master, 1600+ = Diamond, 1200+ = Platinum, 800+ = Gold, else Silver
func tier_from_elo(Rating) = if Rating >= cast(2400, u32) then cast(1, u32) else if Rating >= cast(2000, u32) then cast(2, u32) else if Rating >= cast(1600, u32) then cast(3, u32) else if Rating >= cast(1200, u32) then cast(4, u32) else if Rating >= cast(800, u32) then cast(5, u32) else cast(6, u32).

// Win rate calculation (returns percentage)
func win_rate(Wins, Total) = (Wins * cast(100, u32)) / Total.

// Kill/death/assist ratio calculation (scaled by 100 for integer precision)
// if Deaths = 0, treat as 1 death for calculation
func kda_ratio(Kills, Deaths, Assists) = if Deaths > cast(0, u32) then (Kills + Assists) * cast(100, u32) / Deaths else (Kills + Assists) * cast(100, u32).

// Rating adjustment for streaks
func streak_bonus(ConsecutiveWins) = if ConsecutiveWins >= cast(10, u32) then cast(50, u32) else if ConsecutiveWins >= cast(5, u32) then cast(25, u32) else if ConsecutiveWins >= cast(3, u32) then cast(10, u32) else cast(0, u32).

// Performance multiplier based on kill/death/assist ratio
func performance_multiplier(KdaScaled) = if KdaScaled >= cast(500, u32) then cast(150, u32) else if KdaScaled >= cast(300, u32) then cast(125, u32) else if KdaScaled >= cast(200, u32) then cast(110, u32) else if KdaScaled >= cast(100, u32) then cast(100, u32) else cast(90, u32).

