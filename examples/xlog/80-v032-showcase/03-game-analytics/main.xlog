// =============================================================================
// Game Analytics - Complete Self-Contained Example
// =============================================================================
// Demonstrates working features:
//   - symbol type for player/item identifiers
//   - Recursive rules for achievement chains and social graphs
//   - Aggregations for leaderboards and statistics
//   - Arithmetic expressions for scoring calculations
//   - Complex join patterns for matchmaking analysis
//
// Domain: Multiplayer game with players, matches, achievements, and guilds
// =============================================================================

// --- Core Entity Predicates ---
pred player(symbol, symbol, u32).         // player_id, username, level
pred player_stats(symbol, u32, u32, u32). // player_id, total_xp, games_played, hours_played
pred region(symbol, symbol).              // region_id, region_name
pred player_region(symbol, symbol).       // player_id, region_id

// --- Match/Session Predicates ---
pred match_result(symbol, symbol, u32, u32, u32). // match_id, player_id, kills, deaths, assists
pred match_info(symbol, symbol, u32, u32).        // match_id, game_mode, duration_seconds, timestamp
pred game_mode(symbol, symbol).                   // mode_id, mode_name

// --- Achievement System ---
pred achievement(symbol, symbol, u32).     // achievement_id, name, points
pred player_achievement(symbol, symbol).   // player_id, achievement_id
pred achievement_requires(symbol, symbol). // achievement_id, prerequisite_id

// --- Social Features ---
pred friend(symbol, symbol).               // player1_id, player2_id (symmetric)
pred guild(symbol, symbol, symbol).        // guild_id, guild_name, leader_id
pred guild_member(symbol, symbol).         // guild_id, player_id
pred guild_rank(symbol, symbol, u32).      // guild_id, player_id, rank (1=leader, 2=officer, 3=member)

// --- Item/Inventory System ---
pred item(symbol, symbol, u32, u32).       // item_id, name, rarity, base_value
pred inventory(symbol, symbol, u32).       // player_id, item_id, quantity
pred item_category(symbol, symbol).        // item_id, category_name

// =============================================================================
// REGIONS
// =============================================================================

region(na, "North America").
region(eu, "Europe").
region(asia, "Asia Pacific").
region(sa, "South America").

