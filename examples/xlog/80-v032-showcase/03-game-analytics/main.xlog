// =============================================================================
// DERIVED ANALYTICS
// =============================================================================

// KDA (Kill-Death-Assist) ratio calculation (scaled by 100 for precision)
pred player_kda(symbol, symbol, u32).
player_kda(PlayerId, Username, KDA) :-
    player(PlayerId, Username, _),
    match_result(_, PlayerId, Kills, Deaths, Assists),
    // KDA = (K + A) / max(D, 1) * 100
    KDA is (Kills + Assists) * cast(100, u32) / (Deaths + cast(1, u32)).

// Average KDA per player
pred avg_kda(symbol, u64).
avg_kda(PlayerId, sum(KDA)) :-
    player_kda(PlayerId, _, KDA).

// Match participation count
pred match_count(symbol, u64).
match_count(PlayerId, count(MatchId)) :- match_result(MatchId, PlayerId, _, _, _).

// Active players (played 3+ matches)
pred active_player(symbol, symbol, u64).
active_player(Username, RegionName, MatchCount) :-
    player(PlayerId, Username, _),
    player_region(PlayerId, RegionId),
    region(RegionId, RegionName),
    match_count(PlayerId, MatchCount),
    MatchCount >= 3.

// Total kills per player
pred total_kills(symbol, u64).
total_kills(PlayerId, sum(Kills)) :- match_result(_, PlayerId, Kills, _, _).

// Top fraggers (20+ total kills)
pred top_fragger(symbol, symbol, u64).
top_fragger(Username, RegionName, TotalKills) :-
    player(PlayerId, Username, _),
    player_region(PlayerId, RegionId),
    region(RegionId, RegionName),
    total_kills(PlayerId, TotalKills),
    TotalKills >= 20.

// =============================================================================
// ACHIEVEMENT CHAIN (Recursive)
// =============================================================================

// All prerequisites for an achievement (transitive)
pred all_prerequisites(symbol, symbol).

// Base case: direct prerequisite
all_prerequisites(AchId, PrereqId) :- achievement_requires(AchId, PrereqId).

// Recursive case: transitive prerequisites
all_prerequisites(AchId, TransPrereq) :-
    achievement_requires(AchId, DirectPrereq),
    all_prerequisites(DirectPrereq, TransPrereq).

// Achievement points per player
pred player_achievement_points(symbol, u64).
player_achievement_points(PlayerId, sum(Points)) :-
    player_achievement(PlayerId, AchId),
    achievement(AchId, _, Points).

// High achievers (100+ achievement points)
pred high_achiever(symbol, symbol, u64).
high_achiever(Username, RegionName, Points) :-
    player(PlayerId, Username, _),
    player_region(PlayerId, RegionId),
    region(RegionId, RegionName),
    player_achievement_points(PlayerId, Points),
    Points >= 100.

// =============================================================================
// SOCIAL NETWORK ANALYSIS
// =============================================================================

// Friend of friend (2-hop connection)
pred friend_of_friend(symbol, symbol).
friend_of_friend(P1, P3) :-
    friend(P1, P2),
    friend(P2, P3),
    P1 != P3,
    P1 != P2.

// Friend count per player
pred friend_count(symbol, u64).
friend_count(PlayerId, count(FriendId)) :- friend(PlayerId, FriendId).

// Popular players (3+ friends)
pred popular_player(symbol, symbol, u64).
popular_player(Username, RegionName, FriendCount) :-
    player(PlayerId, Username, _),
    player_region(PlayerId, RegionId),
    region(RegionId, RegionName),
    friend_count(PlayerId, FriendCount),
    FriendCount >= 3.

// =============================================================================
// GUILD ANALYTICS
// =============================================================================

// Guild member count
pred guild_size(symbol, u64).
guild_size(GuildId, count(PlayerId)) :- guild_member(GuildId, PlayerId).

// Guild total level (sum of member levels)
pred guild_power(symbol, u64).
guild_power(GuildId, sum(Level)) :-
    guild_member(GuildId, PlayerId),
    player(PlayerId, _, Level).

// Top guilds (power >= 100)
pred top_guild(symbol, symbol, u64, u64).
top_guild(GuildName, LeaderName, MemberCount, Power) :-
    guild(GuildId, GuildName, LeaderId),
    player(LeaderId, LeaderName, _),
    guild_size(GuildId, MemberCount),
    guild_power(GuildId, Power),
    Power >= 100.

// =============================================================================
// INVENTORY ANALYTICS
// =============================================================================

// Total inventory value per player
pred inventory_value(symbol, u64).
inventory_value(PlayerId, sum(TotalValue)) :-
    inventory(PlayerId, ItemId, Quantity),
    item(ItemId, _, _, BaseValue),
    TotalValue is Quantity * BaseValue.

// Wealthy players (inventory value >= 1000)
pred wealthy_player(symbol, symbol, u64).
wealthy_player(Username, RegionName, Value) :-
    player(PlayerId, Username, _),
    player_region(PlayerId, RegionId),
    region(RegionId, RegionName),
    inventory_value(PlayerId, Value),
    Value >= 1000.

// Rare item owners (rarity >= 3)
pred rare_item_owner(symbol, symbol, symbol, u32).
rare_item_owner(Username, ItemName, Category, Rarity) :-
    player(PlayerId, Username, _),
    inventory(PlayerId, ItemId, _),
    item(ItemId, ItemName, Rarity, _),
    item_category(ItemId, Category),
    Rarity >= 3.

// =============================================================================
// REGIONAL ANALYTICS
// =============================================================================

// Players per region
pred region_player_count(symbol, u64).
region_player_count(RegionId, count(PlayerId)) :- player_region(PlayerId, RegionId).

// Region total XP
pred region_total_xp(symbol, u64).
region_total_xp(RegionId, sum(XP)) :-
    player_region(PlayerId, RegionId),
    player_stats(PlayerId, XP, _, _).

// Active regions (50000+ total XP)
pred active_region(symbol, symbol, u64, u64).
active_region(RegionName, RegionId, PlayerCount, TotalXP) :-
    region(RegionId, RegionName),
    region_player_count(RegionId, PlayerCount),
    region_total_xp(RegionId, TotalXP),
    TotalXP >= 50000.

// =============================================================================
// QUERIES
// =============================================================================

// Q1: Top fraggers by region
?- top_fragger(Username, Region, TotalKills).

// Q2: High achievers with achievement points
?- high_achiever(Username, Region, Points).

// Q3: Top guilds with power ratings
?- top_guild(GuildName, LeaderName, Members, Power).

// Q4: Active regions with statistics
?- active_region(RegionName, RegionId, PlayerCount, TotalXP).

// Q5: Wealthy players with inventory value
?- wealthy_player(Username, Region, InventoryValue).

// Q6: Players with rare items
?- rare_item_owner(Username, ItemName, Category, Rarity).

// Q7: Achievement prerequisite chains
?- all_prerequisites(a009, Prereq).
