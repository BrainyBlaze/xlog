// =============================================================================
// DERIVED PREDICATES
// =============================================================================

// Match participation count per player
pred match_count(symbol, u64).
match_count(PlayerId, count(MatchId)) :- match_result(MatchId, PlayerId, _, _, _).

// Win count per player
pred win_count(symbol, u64).
win_count(PlayerId, count(MatchId)) :- match_winner(MatchId, PlayerId).

// Total kills per player
pred total_kills(symbol, u64).
total_kills(PlayerId, sum(Kills)) :- match_result(_, PlayerId, Kills, _, _).

// Total deaths per player
pred total_deaths(symbol, u64).
total_deaths(PlayerId, sum(Deaths)) :- match_result(_, PlayerId, _, Deaths, _).

// Total assists per player
pred total_assists(symbol, u64).
total_assists(PlayerId, sum(Assists)) :- match_result(_, PlayerId, _, _, Assists).

// Matches per game mode
pred mode_match_count(symbol, u64).
mode_match_count(ModeId, count(MatchId)) :- match_info(MatchId, ModeId, _, _).

// Valid match check (meets minimum duration)
pred valid_match(symbol).
valid_match(MatchId) :-
    match_info(MatchId, _, Duration, _),
    min_match_duration(MinDuration),
    Duration >= MinDuration.
