// =============================================================================
// Match History Module
// =============================================================================
// Demonstrates: Large-scale fact storage, game modes, match results
// Contains: 110 matches with kills/deaths/assists data
// =============================================================================

// --- Predicate Declarations ---
pred game_mode(symbol, symbol).                        // mode_id, mode_name
pred match_info(symbol, symbol, u32, u32).             // match_id, game_mode, duration_seconds, timestamp
pred match_result(symbol, symbol, u32, u32, u32).      // match_id, player_id, kills, deaths, assists
pred match_winner(symbol, symbol).                      // match_id, player_id (winner)

// --- Private Helpers ---
pred min_match_duration(u32).
min_match_duration(300).  // Minimum 5 minutes for valid match

// =============================================================================
// GAME MODES (6 modes)
// =============================================================================

game_mode(dm, "Deathmatch").
game_mode(tdm, "Team Deathmatch").
game_mode(ctf, "Capture the Flag").
game_mode(ranked, "Ranked Competitive").
game_mode(casual, "Casual Play").
game_mode(battle_royale, "Battle Royale").

