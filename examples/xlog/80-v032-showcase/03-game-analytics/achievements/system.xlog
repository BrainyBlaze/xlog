// =============================================================================
// RECURSIVE RULES - Achievement Prerequisite Chain
// =============================================================================

// All prerequisites for an achievement (transitive closure)
pred all_prerequisites(symbol, symbol).

// Base case: direct prerequisite
all_prerequisites(AchId, PrereqId) :- achievement_requires(AchId, PrereqId).

// Recursive case: transitive prerequisites
all_prerequisites(AchId, TransPrereq) :-
    achievement_requires(AchId, DirectPrereq),
    all_prerequisites(DirectPrereq, TransPrereq).

// =============================================================================
// DERIVED PREDICATES
// =============================================================================

// Achievement points calculation per player
// Note: sum(u32) returns u64
pred player_achievement_points(symbol, u64).
player_achievement_points(PlayerId, sum(Points)) :-
    player_achievement(PlayerId, AchId),
    achievement(AchId, _, Rarity),
    Points is achievement_points(Rarity).

// Count achievements per player
pred player_achievement_count(symbol, u64).
player_achievement_count(PlayerId, count(AchId)) :- player_achievement(PlayerId, AchId).

// High achievers (200+ achievement points)
pred high_achiever(symbol, u64).
high_achiever(PlayerId, Points) :-
    player_achievement_points(PlayerId, Points),
    Points >= 200.

// Legendary achievement holders
pred legendary_holder(symbol, symbol).
legendary_holder(PlayerId, AchName) :-
    player_achievement(PlayerId, AchId),
    achievement(AchId, AchName, Rarity),
    legendary_rarity(Rarity).

// Count achievements per category
pred category_count(symbol, u64).
category_count(Category, count(AchId)) :- achievement_category(AchId, Category).

// Missing prerequisites for a player
pred missing_prerequisite(symbol, symbol, symbol).
missing_prerequisite(PlayerId, AchId, PrereqId) :-
    player_achievement(PlayerId, AchId),
    all_prerequisites(AchId, PrereqId),
    not player_achievement(PlayerId, PrereqId).
