// =============================================================================
// Achievement System Module
// =============================================================================
// Demonstrates: Recursive prerequisite chains, user-defined functions for points calculation
// Contains: 25 achievements with complex prerequisite relationships
// =============================================================================

// --- Predicate Declarations ---
pred achievement(symbol, symbol, u32).         // achievement_id, name, rarity (1=legendary, 2=epic, 3=rare, 4=common)
pred achievement_requires(symbol, symbol).     // achievement_id, prerequisite_id
pred player_achievement(symbol, symbol).       // player_id, achievement_id
pred achievement_category(symbol, symbol).     // achievement_id, category

// --- Private Helpers ---
pred legendary_rarity(u32).
pred epic_rarity(u32).
pred rare_rarity(u32).
pred common_rarity(u32).

legendary_rarity(1).
epic_rarity(2).
rare_rarity(3).
common_rarity(4).

// =============================================================================
// USER-DEFINED FUNCTIONS
// =============================================================================

// Achievement points based on rarity
// Rarity 1 (Legendary) = 100 points, Rarity 2 (Epic) = 50, Rarity 3 (Rare) = 25, Common = 10
func achievement_points(Rarity) = if Rarity = cast(1, u32) then cast(100, u32) else if Rarity = cast(2, u32) then cast(50, u32) else if Rarity = cast(3, u32) then cast(25, u32) else cast(10, u32).

// =============================================================================
// ACHIEVEMENT DEFINITIONS (25 achievements)
// =============================================================================

// --- Combat Chain (6 achievements) ---
achievement(a001, first_blood, 4).           // Common - Get first kill
achievement(a002, killing_spree, 3).         // Rare - 5 kills without dying
achievement(a003, unstoppable, 2).           // Epic - 10 kills without dying
achievement(a004, legendary_warrior, 1).     // Legendary - 20 kills without dying
achievement(a005, godlike, 1).               // Legendary - 30 kills without dying
achievement(a006, demigod, 1).               // Legendary - 50 kills without dying

// --- Team Play Chain (4 achievements) ---
achievement(a007, team_player, 4).           // Common - 10 assists
achievement(a008, support_specialist, 3).    // Rare - 50 assists
achievement(a009, support_master, 2).        // Epic - 100 assists
achievement(a010, ultimate_support, 1).      // Legendary - 250 assists

// --- Experience Chain (5 achievements) ---
achievement(a011, beginner, 4).              // Common - Complete tutorial
achievement(a012, veteran, 3).               // Rare - 100 games played
achievement(a013, elite, 2).                 // Epic - 500 games played
achievement(a014, champion, 1).              // Legendary - 1000 games played
achievement(a015, immortal_legend, 1).       // Legendary - 2000 games played

// --- Win Streak Chain (4 achievements) ---
achievement(a016, first_win, 4).             // Common - Win first match
achievement(a017, winning_streak, 3).        // Rare - Win 5 matches in a row
achievement(a018, dominant_force, 2).        // Epic - Win 10 matches in a row
achievement(a019, undefeated, 1).            // Legendary - Win 20 matches in a row

// --- Social Chain (3 achievements) ---
achievement(a020, social_butterfly, 4).      // Common - Add 5 friends
achievement(a021, community_leader, 3).      // Rare - Add 20 friends
achievement(a022, guild_master, 2).          // Epic - Lead a guild with 10+ members

// --- Special Achievements (3 achievements) ---
achievement(a023, accuracy_king, 2).         // Epic - 80%+ accuracy in a match
achievement(a024, survivor, 3).              // Rare - Win Battle Royale
achievement(a025, perfectionist, 1).         // Legendary - Complete all other achievements

