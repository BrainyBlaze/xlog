// ACHIEVEMENT CATEGORIES
// =============================================================================

achievement_category(a001, combat).
achievement_category(a002, combat).
achievement_category(a003, combat).
achievement_category(a004, combat).
achievement_category(a005, combat).
achievement_category(a006, combat).
achievement_category(a007, teamwork).
