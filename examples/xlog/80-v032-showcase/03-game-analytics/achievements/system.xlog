achievement_category(a018, winning).
achievement_category(a019, winning).
achievement_category(a020, social).
achievement_category(a021, social).
achievement_category(a022, social).
achievement_category(a023, skill).
achievement_category(a024, skill).
achievement_category(a025, completion).

// =============================================================================
// PREREQUISITE CHAINS (Achievement Dependencies)
// =============================================================================

// Combat chain: First Blood -> Killing Spree -> Unstoppable -> Legendary -> Godlike -> Demigod
achievement_requires(a002, a001).  // Killing Spree requires First Blood
achievement_requires(a003, a002).  // Unstoppable requires Killing Spree
achievement_requires(a004, a003).  // Legendary Warrior requires Unstoppable
achievement_requires(a005, a004).  // Godlike requires Legendary Warrior
achievement_requires(a006, a005).  // Demigod requires Godlike

// Team play chain: Team Player -> Support Specialist -> Support Master -> Ultimate Support
achievement_requires(a008, a007).  // Support Specialist requires Team Player
achievement_requires(a009, a008).  // Support Master requires Support Specialist
achievement_requires(a010, a009).  // Ultimate Support requires Support Master

// Experience chain: Beginner -> Veteran -> Elite -> Champion -> Immortal Legend
achievement_requires(a012, a011).  // Veteran requires Beginner
achievement_requires(a013, a012).  // Elite requires Veteran
achievement_requires(a014, a013).  // Champion requires Elite
achievement_requires(a015, a014).  // Immortal Legend requires Champion

// Win streak chain: First Win -> Winning Streak -> Dominant Force -> Undefeated
achievement_requires(a017, a016).  // Winning Streak requires First Win
achievement_requires(a018, a017).  // Dominant Force requires Winning Streak
achievement_requires(a019, a018).  // Undefeated requires Dominant Force

// Social chain: Social Butterfly -> Community Leader -> Guild Master
achievement_requires(a021, a020).  // Community Leader requires Social Butterfly
achievement_requires(a022, a021).  // Guild Master requires Community Leader

// Perfectionist requires all legendary achievements
achievement_requires(a025, a006).  // Perfectionist requires Demigod
achievement_requires(a025, a010).  // Perfectionist requires Ultimate Support
achievement_requires(a025, a015).  // Perfectionist requires Immortal Legend
achievement_requires(a025, a019).  // Perfectionist requires Undefeated

