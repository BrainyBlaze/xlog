// =============================================================================
// Player Profiles Module
// =============================================================================
// Demonstrates: symbol type for player identifiers, countries, and statuses
// Contains: 55 players with comprehensive profile data
// =============================================================================

// --- Predicate Declarations ---
pred player(symbol, symbol, symbol, symbol).   // player, username, country, status
pred player_stats(symbol, u32, u32, u32).      // player, total experience, games played, hours played
pred region(symbol, symbol).                   // region, region name
pred player_region(symbol, symbol).            // player, region
pred friend(symbol, symbol).                   // first player, second player (symmetric)
pred guild(symbol, symbol, symbol).            // guild, guild name, leader
pred guild_member(symbol, symbol).             // guild, player

// --- Private Helpers ---
pred active_threshold(u32).
active_threshold(300).  // 300+ hours = active

// --- Regions ---
region(na, "North America").
region(eu, "Europe").
region(asia, "Asia Pacific").
region(sa, "South America").
region(oce, "Oceania").

