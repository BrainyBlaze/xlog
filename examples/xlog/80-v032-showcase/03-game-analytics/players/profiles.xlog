// =============================================================================
// DERIVED PREDICATES
// =============================================================================

// Friend count per player
pred friend_count(symbol, u64).
friend_count(Player, count(Friend)) :- friend(Player, Friend).

// Active player check (300+ hours)
pred is_active_player(symbol).
is_active_player(Player) :-
    player_stats(Player, _, _, Hours),
    active_threshold(Threshold),
    Hours >= Threshold.

// Friend of friend (2-hop social connection, avoiding self-loops)
pred friend_of_friend(symbol, symbol).
friend_of_friend(FirstPlayer, CandidateFriend) :-
    friend(FirstPlayer, MutualFriend),
    friend(MutualFriend, CandidateFriend),
    FirstPlayer != CandidateFriend,
    FirstPlayer != MutualFriend.

// Guild member count
pred guild_size(symbol, u64).
guild_size(Guild, count(Player)) :- guild_member(Guild, Player).

// Popular players (3+ friends)
pred popular_player(symbol, symbol, u64).
popular_player(Username, RegionName, FriendCount) :-
    player(Player, Username, _, active),
    player_region(Player, Region),
    region(Region, RegionName),
    friend_count(Player, FriendCount),
    FriendCount >= 3.
